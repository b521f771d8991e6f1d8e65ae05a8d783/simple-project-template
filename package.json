{
  "main": "expo-router/entry",
  "scripts": {
    "compile:web": "EXPO_NO_TELEMETRY=1 node node_modules/.bin/expo export --platform web",
    "compile:server": "esbuild src/server.ts --outfile=./dist/main.js --platform=node --bundle --minify --define:__APP_VERSION__=\\\"$(npx tsx scripts/version.ts)\\\"",
    "compile:worker": "esbuild src/worker.ts --outfile=./dist/worker.js --platform=browser --bundle --minify --format=esm --external:node:* --define:__APP_VERSION__=\\\"$(npx tsx scripts/version.ts)\\\"",
    "compile:native:wasm": "emcmake cmake --preset release -B .cmake-wasm -S . && cmake --build .cmake-wasm && mkdir -p dist && cp -a .cmake-wasm/*.a dist",
    "compile:native:native": "cmake --preset release -B .cmake -S . && cmake --build .cmake",
    "compile:rust:wasm": "wasm-pack build --release --out-dir dist/rust --target web",
    "compile:rust:native": "cargo build --release",
    "build:node": "npm run compile:native:wasm && npm run compile:rust:wasm && npm run compile:web && npm run compile:server",
    "build:cloudflare-worker": "npm run compile:native:wasm && npm run compile:rust:wasm && npm run compile:web && npm run compile:worker",
    "build:web": "npm run compile:native:wasm && npm run compile:rust:wasm && npm run compile:web && npm run compile:server && npm run compile:worker",
    "compile:server:sea": "npm run compile:server && node --experimental-sea-config sea-config.json && mkdir -p dist/binaries && cp \"$(node -e 'process.stdout.write(process.execPath)')\" dist/binaries/server && chmod u+w dist/binaries/server && npx postject dist/binaries/server NODE_SEA_BLOB dist/sea-prep.blob --sentinel-fuse NODE_SEA_FUSE_fce680ab2cc467b6e072b8b5df1996b2 --macho-segment-name NODE_SEA",
    "build:tauri": "npm run compile:native:native && npm run compile:rust:native && npm run compile:web && npm run compile:server:sea && cargo tauri build --config tauri.conf.json --no-bundle --features tauri-app",
    "dev": "APP_MODE=develop expo start --web",
    "lint": "expo lint",
    "version": "tsx scripts/version.ts",
    "tag": "tsx scripts/tag.ts",
    "tag:push": "tsx scripts/tag.ts --push",
    "test": "(cd .cmake && ctest ) && cargo test && jest"
  },
  "dependencies": {
    "@anthropic-ai/claude-code": "^2.1.91",
    "@expo/vector-icons": "^15.1.1",
    "@react-native-async-storage/async-storage": "^3.0.2",
    "@react-navigation/bottom-tabs": "^7.15.9",
    "@react-navigation/elements": "^2.9.14",
    "@react-navigation/native": "^7.2.2",
    "@reduxjs/toolkit": "^2.11.2",
    "@resvg/resvg-js": "^2.6.2",
    "@types/compression": "^1.8.1",
    "@types/express": "^5.0.6",
    "@types/jest": "29.5.14",
    "@types/morgan": "^1.9.10",
    "@types/react": "~19.1.17",
    "compression": "^1.8.1",
    "expo": "~54.0.33",
    "expo-constants": "~18.0.13",
    "expo-font": "~14.0.11",
    "expo-haptics": "~15.0.8",
    "expo-image": "~3.0.11",
    "expo-linking": "~8.0.11",
    "expo-router": "~6.0.23",
    "expo-splash-screen": "~31.0.13",
    "expo-status-bar": "~3.0.9",
    "expo-symbols": "~1.0.8",
    "expo-system-ui": "~6.0.9",
    "expo-web-browser": "~15.0.10",
    "express": "^5.2.1",
    "helmet": "^8.1.0",
    "html2canvas": "^1.4.1",
    "jest": "~29.7.0",
    "jest-expo": "~54.0.17",
    "morgan": "^1.10.1",
    "nativewind": "^4.2.3",
    "nodemailer": "^8.0.4",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-markdown-display": "^7.0.2",
    "react-native-reanimated": "~4.1.7",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "^15.15.4",
    "react-native-web": "~0.21.2",
    "react-native-worklets": "0.5.1",
    "react-redux": "^9.2.0"
  },
  "devDependencies": {
    "@dotenvx/dotenvx": "^1.59.1",
    "@resvg/resvg-js": "^2.6.2",
    "@types/compression": "^1.8.1",
    "@types/express": "^5.0.6",
    "@types/morgan": "^1.9.10",
    "@types/nodemailer": "^8.0.0",
    "@types/react": "~19.1.17",
    "esbuild": "^0.27.7",
    "eslint": "^9.39.4",
    "eslint-config-expo": "~10.0.0",
    "postject": "^1.0.0-alpha.6",
    "tailwindcss": "^3.4.19",
    "tsx": "^4.21.0",
    "typescript": "~5.9.3"
  },
  "private": true
}