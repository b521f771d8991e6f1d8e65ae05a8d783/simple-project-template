{
  "main": "expo-router/entry",
  "scripts": {
    "compile:web": "EXPO_NO_TELEMETRY=1 node node_modules/.bin/expo export --platform web",
    "compile:server": "esbuild src/server.ts --outfile=./dist/main.js --platform=node --bundle --minify --define:__APP_VERSION__=\\\"$(npx tsx scripts/version.ts)\\\"",
    "compile:server:dev": "esbuild src/server.ts --outfile=./dist/main.js --platform=node --bundle --sourcemap --define:__APP_VERSION__=\\\"$(npx tsx scripts/version.ts)\\\"",
    "compile:worker": "esbuild src/worker.ts --outfile=./dist/worker.js --platform=browser --bundle --minify --format=esm --external:node:* --define:__APP_VERSION__=\\\"$(npx tsx scripts/version.ts)\\\"",
    "compile:worker:dev": "esbuild src/worker.ts --outfile=./dist/worker.js --platform=browser --bundle --sourcemap --format=esm --external:node:* --define:__APP_VERSION__=\\\"$(npx tsx scripts/version.ts)\\\"",
    "build:node": "npm run compile:web && npm run compile:server",
    "build:node:dev": "npm run compile:web && npm run compile:server:dev",
    "build:cloudflare-worker": "npm run compile:web && npm run compile:worker",
    "build:cloudflare-worker:dev": "npm run compile:web && npm run compile:worker:dev",
    "dev": "APP_MODE=develop expo start --web",
    "lint": "expo lint",
    "version": "tsx scripts/version.ts",
    "tag": "tsx scripts/tag.ts",
    "tag:push": "tsx scripts/tag.ts --push",
    "generate:icons": "tsx scripts/generate-icons.ts"
  },
  "dependencies": {
    "@anthropic-ai/claude-code": "^2.1.91",
    "@dotenvx/dotenvx": "^1.59.1",
    "@expo/vector-icons": "^15.1.1",
    "@react-native-async-storage/async-storage": "^3.0.2",
    "@react-navigation/bottom-tabs": "^7.15.9",
    "@react-navigation/elements": "^2.9.14",
    "@react-navigation/native": "^7.2.2",
    "@reduxjs/toolkit": "^2.11.2",
    "@resvg/resvg-js": "^2.6.2",
    "@types/compression": "^1.8.1",
    "@types/express": "^5.0.6",
    "@types/morgan": "^1.9.10",
    "@types/react": "~19.1.17",
    "compression": "^1.8.1",
    "esbuild": "^0.27.7",
    "eslint": "^9.39.4",
    "eslint-config-expo": "~10.0.0",
    "expo": "~54.0.33",
    "expo-constants": "~18.0.13",
    "expo-font": "~14.0.11",
    "expo-haptics": "~15.0.8",
    "expo-image": "~3.0.11",
    "expo-linking": "~8.0.11",
    "expo-router": "~6.0.23",
    "expo-splash-screen": "~31.0.13",
    "expo-status-bar": "~3.0.9",
    "expo-symbols": "~1.0.8",
    "expo-system-ui": "~6.0.9",
    "expo-web-browser": "~15.0.10",
    "express": "^5.2.1",
    "helmet": "^8.1.0",
    "html2canvas": "^1.4.1",
    "morgan": "^1.10.1",
    "nativewind": "^4.2.3",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-markdown-display": "^7.0.2",
    "react-native-reanimated": "~4.1.7",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "^15.15.4",
    "react-native-web": "~0.21.2",
    "react-native-worklets": "0.5.1",
    "react-redux": "^9.2.0",
    "tailwindcss": "^3.4.19",
    "typescript": "~5.9.3",
    "wrangler": "^4.80.0"
  },
  "private": true
}
