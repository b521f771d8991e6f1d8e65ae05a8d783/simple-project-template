{
  "main": "expo-router/entry",
  "scripts": {
    "compile:wasm": "cargo build --target wasm32-unknown-unknown --lib --release && mkdir -p src/wasm && wasm-bindgen --target web --out-dir src/wasm target/wasm32-unknown-unknown/release/simple_project_template.wasm",
    "compile:wasm:dev": "cargo build --target wasm32-unknown-unknown --lib && mkdir -p src/wasm && wasm-bindgen --target web --out-dir src/wasm target/wasm32-unknown-unknown/debug/simple_project_template.wasm",
    "compile:web": "expo export --platform web",
    "compile:server": "esbuild src/server.ts --outfile=./dist/main.js --platform=node --bundle --minify --define:__APP_VERSION__=\\\"$(npx tsx scripts/version.ts)\\\"",
    "compile:server:dev": "esbuild src/server.ts --outfile=./dist/main.js --platform=node --bundle --sourcemap --define:__APP_VERSION__=\\\"$(npx tsx scripts/version.ts)\\\"",
    "compile:worker": "esbuild src/worker.ts --outfile=./dist/worker.js --platform=browser --bundle --minify --format=esm --external:node:* --define:__APP_VERSION__=\\\"$(npx tsx scripts/version.ts)\\\"",
    "compile:worker:dev": "esbuild src/worker.ts --outfile=./dist/worker.js --platform=browser --bundle --sourcemap --format=esm --external:node:* --define:__APP_VERSION__=\\\"$(npx tsx scripts/version.ts)\\\"",
    "build:node": "npm run compile:wasm && npm run compile:web && npm run compile:server",
    "build:node:dev": "npm run compile:wasm:dev && npm run compile:web && npm run compile:server:dev",
    "build:cloudflare-worker": "npm run compile:wasm && EXPO_NO_TELEMETRY=1 npm run compile:web && npm run compile:worker",
    "build:cloudflare-worker:dev": "npm run compile:wasm:dev && EXPO_NO_TELEMETRY=1 npm run compile:web && npm run compile:worker:dev",
    "develop": "npm run compile:wasm:dev && bacon --headless -- --target wasm32-unknown-unknown --lib & expo start --web & wait",
    "dream": "npm run compile:wasm:dev && bacon --headless -- --target wasm32-unknown-unknown --lib & APP_MODE=dream expo start --web & wait",
    "build": "NODE_ENV=production npm run build:node",
    "build:worker": "NODE_ENV=production npm run build:cloudflare-worker",
    "lint": "expo lint && cargo check",
    "version": "npx tsx scripts/version.ts",
    "tag": "npx tsx scripts/tag.ts",
    "tag:push": "npx tsx scripts/tag.ts --push",
    "generate:icons": "npx tsx scripts/generate-icons.ts"
  },
  "dependencies": {
    "@anthropic-ai/claude-code": "^2.1.90",
    "@dotenvx/dotenvx": "^1.59.1",
    "@expo/vector-icons": "^15.0.3",
    "@react-navigation/bottom-tabs": "^7.4.0",
    "@react-navigation/elements": "^2.6.3",
    "@react-navigation/native": "^7.1.8",
    "@reduxjs/toolkit": "^2.11.2",
    "@resvg/resvg-js": "^2.6.2",
    "@types/compression": "^1.8.1",
    "@types/express": "^5.0.6",
    "@types/morgan": "^1.9.10",
    "@types/react": "~19.1.0",
    "compression": "^1.8.1",
    "esbuild": "^0.27.4",
    "eslint": "^9.25.0",
    "eslint-config-expo": "~10.0.0",
    "expo": "~54.0.33",
    "expo-constants": "~18.0.13",
    "expo-font": "~14.0.11",
    "expo-haptics": "~15.0.8",
    "expo-image": "~3.0.11",
    "expo-linking": "~8.0.11",
    "expo-router": "~6.0.23",
    "expo-splash-screen": "~31.0.13",
    "expo-status-bar": "~3.0.9",
    "expo-symbols": "~1.0.8",
    "expo-system-ui": "~6.0.9",
    "expo-web-browser": "~15.0.10",
    "express": "^5.2.1",
    "helmet": "^8.1.0",
    "morgan": "^1.10.1",
    "nativewind": "^4.2.1",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "^15.15.4",
    "react-native-web": "~0.21.0",
    "react-native-worklets": "0.5.1",
    "react-redux": "^9.2.0",
    "tailwindcss": "^3.4.17",
    "typescript": "~5.9.2",
    "wrangler": "^4.78.0"
  },
  "private": true
}