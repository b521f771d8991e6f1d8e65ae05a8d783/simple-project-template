# Files and patterns protected from Dream Mode edits.
# One entry per line. Supports exact paths and glob prefixes (e.g. "scripts/").
# Lines starting with # are comments.

# Build and deploy config
wrangler.jsonc
flake.nix
flake.lock
tsconfig.json
babel.config.js
metro.config.js
tailwind.config.js
eslint.config.js
app.config.ts
.prettierrc
.npmrc
.devcontainer.json

# Environment and secrets
.env
.env.local

# CI/CD
.github/

# Nix and git
.gitignore
.do-not-edit
AGENTS.md

# Build scripts and tooling
scripts/

# Server infrastructure (Dream Mode should not modify its own endpoints)
src/server.ts
src/worker.ts
src/server/
src/app/api/

# Protected components (Dream Mode's own UI)
src/app/(tabs)/_layout.tsx
src/app/_layout.tsx
src/lib/version.ts
