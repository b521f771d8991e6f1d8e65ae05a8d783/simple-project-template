DOTENV_PUBLIC_KEY="02ac6f0b878fe86d27c9dfb8b989287319b6254f0d3b841750a6faa0fd9caba4a6"

# .env
# project identity — single source of truth for all build systems
PROJECT_NAME=simple-project-template

# run time configuration
BACKEND_LISTEN_PORT=8081
BACKEND_LISTEN_HOSTNAME=0.0.0.0

# dream mode — email diffs to the developer instead of applying changes
DEVELOPER_EMAIL=
SMTP_URL=smtp://user:pass@smtp.example.com:587